  "keyFeatures": [
    "Zero-dependency core — no Redux, Zustand, or Context API required",
    "Fine-grained selector subscriptions to eliminate unnecessary re-renders",
    "Batch updates via setMultiple for atomic multi-key state changes",
    "Optional Immer integration for mutation-style nested state updates",
    "Custom hook pattern for clean, scalable multi-store architectures",
    "Built on React's useSyncExternalStore for concurrent-mode safety"
  ],
  "publicApiSurface": [
    "createStore(initialState) → Store",
    "store.getState() → State",
    "store.subscribe(listener) → unsubscribe",
    "store.setState(selectKeyFn, nextStateOrFn)",
    "store.setMultiple(nextStateOrFn, replaceStore?)",
    "useStore(storeRef, selector?) → SelectedState",
    "immer(storeRef) → ImmerWrappedStore"
  ]
}
